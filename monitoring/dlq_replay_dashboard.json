{
  "displayName": "DLQ Replay Dashboard",
  "gridLayout": {
    "columns": "2",
    "widgets": [
      {
        "title": "Replay Counter Overview",
        "xyChart": {
          "dataSets": [
            {
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "filter": "metric.type=\"dataflow.googleapis.com/job/user_counter\" resource.type=\"dataflow_job\" metric.labels.metric_name=\"fetched\"",
                  "aggregation": {
                    "alignmentPeriod": "180s",
                    "perSeriesAligner": "ALIGN_MAX",
                    "crossSeriesReducer": "REDUCE_SUM",
                    "groupByFields": []
                  }
                }
              },
              "plotType": "LINE",
              "legendTemplate": "Fetched"
            },
            {
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "filter": "metric.type=\"dataflow.googleapis.com/job/user_counter\" resource.type=\"dataflow_job\" metric.labels.metric_name=\"replayed\"",
                  "aggregation": {
                    "alignmentPeriod": "180s",
                    "perSeriesAligner": "ALIGN_MAX",
                    "crossSeriesReducer": "REDUCE_SUM",
                    "groupByFields": []
                  }
                }
              },
              "plotType": "LINE",
              "legendTemplate": "Replayed"
            },
            {
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "filter": "metric.type=\"dataflow.googleapis.com/job/user_counter\" resource.type=\"dataflow_job\" metric.labels.metric_name=\"fixed_and_replayed\"",
                  "aggregation": {
                    "alignmentPeriod": "180s",
                    "perSeriesAligner": "ALIGN_MAX",
                    "crossSeriesReducer": "REDUCE_SUM",
                    "groupByFields": []
                  }
                }
              },
              "plotType": "LINE",
              "legendTemplate": "Fixed And Replayed"
            },
            {
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "filter": "metric.type=\"dataflow.googleapis.com/job/user_counter\" resource.type=\"dataflow_job\" metric.labels.metric_name=\"fixed_only\"",
                  "aggregation": {
                    "alignmentPeriod": "180s",
                    "perSeriesAligner": "ALIGN_MAX",
                    "crossSeriesReducer": "REDUCE_SUM",
                    "groupByFields": []
                  }
                }
              },
              "plotType": "LINE",
              "legendTemplate": "Fix Only"
            }
          ],
          "timeshiftDuration": "0s",
          "yAxis": {
            "label": "Messages / 3 min",
            "scale": "LINEAR"
          }
        }
      },
